(executable
 (name example)
 (libraries
   landmark
   landmarks_exports
 )
 (preprocess
  (pps ppx_landmarks)))

(executable
 (name test)
 (libraries
   landmark
   landmarks_exports
 )
)

(rule
 (with-stdout-to test.out
  (run ./test.exe)))

(rule
 (alias runtest)
 (package landmarks)
 (action
  (diff test.out.expected test.out)))
